{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "script"
  },
  "globals": {
    "io": "readonly",
    "Socket": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "semi": ["warn", "always"],
    "no-undef": "warn",
    "eqeqeq": ["warn", "always"],
    "no-var": "off"
  },
  "ignorePatterns": [
    "node_modules/",
    "static/js/vendor/",
    "static/js/socket.io.min.js"
  ]
}
